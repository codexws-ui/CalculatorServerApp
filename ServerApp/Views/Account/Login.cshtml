@using System.Text.Json;
@using Microsoft.AspNetCore.Authentication
@using ServerApp
@using ServerApp.Models

@model LoginVM

@{
    ViewData["Title"] = "Login";

    string? returnUrl = (string?)TempData.Peek("ReturnUrl");
    string? external = (string?)TempData.Peek("ExternalLogins");

    IList<AuthenticationScheme>? externalLogins = external == null ? null : JsonSerializer.Deserialize<IList<AuthenticationScheme>>(external);
}

<h1>@ViewData["Title"]</h1>

<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-antiforgery="true" id="account" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

            <div class="row">
                <div class="col-12 mb-3">
                    <div class="form-floating">
                        <input asp-for="Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                        <label asp-for="Email" class="form-label"></label>
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-xl-6 mb-3">
                    <div class="form-floating">
                        <input asp-for="Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="password" />
                        <label asp-for="Password" class="form-label"></label>
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>
                </div>
                <div class="col-xl-6 mb-3">
                    <div class="checkbox">
                        <label asp-for="RememberMe" class="form-label">
                            <input class="form-check-input" asp-for="RememberMe" />
                            @Html.DisplayNameFor(m => m.RememberMe)
                        </label>
                    </div>
                </div>
                <div class="col-6 mb-3">
                    <button id="login-submit" type="submit" class="w-100 btn btn-lg btn-primary">Login</button>
                </div>
                <div class="col-6 mb-3">
                    <a id="register" asp-controller="Account" asp-action="Register">Register</a>
                </div>
            </div>
        </form>
    </div>
    <div class="col-md-6">
        <b>Email</b>: codex.ws@gmail.com
        <br />
        <b>Password</b>: 111111
        <br />
        Or <a asp-controller="Account" asp-action="Register">Register</a> Your Own
    </div>
</div>


@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
